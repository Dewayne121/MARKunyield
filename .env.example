# ============================================
# UNYIELD React Native App Configuration
# ============================================
#
# Copy this file to .env and uncomment the line you need
#

# Production (Railway) - Default
# EXPO_PUBLIC_API_URL=https://unyielding-api-production.up.railway.app

# Local Development
# EXPO_PUBLIC_API_URL=http://localhost:3000

# Custom URL (e.g., your LAN IP for mobile testing)
# EXPO_PUBLIC_API_URL=http://192.168.1.100:3000

# Optional fallback URL(s) used when the primary API endpoint is unreachable
# You can provide a comma-separated list
# EXPO_PUBLIC_API_FALLBACK_URL=https://backup-tunnel.example,https://unyield-main.onrender.com

# Emergency non-tunnel fallback appended automatically in remote sessions
# EXPO_PUBLIC_API_EMERGENCY_URL=https://unyield-main.onrender.com

# Remote tunnel bootstrap (scripts/startRemoteDev.js)
# Keep Metro on localtunnel by default to avoid Cloudflare 530 quick-tunnel errors in Expo Go.
# METRO_TUNNEL_PROVIDER=localtunnel
# TUNNEL_PROVIDER=auto
