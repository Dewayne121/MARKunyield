# ============================================
# UNYIELD React Native App Configuration
# ============================================
#
# Copy this file to .env and uncomment the line you need
#

# Production (Railway) - Default
# EXPO_PUBLIC_API_URL=https://unyielding-api-production.up.railway.app

# Local Development
# EXPO_PUBLIC_API_URL=http://localhost:3000

# Custom URL (e.g., your LAN IP for mobile testing)
# EXPO_PUBLIC_API_URL=http://192.168.1.100:3000
